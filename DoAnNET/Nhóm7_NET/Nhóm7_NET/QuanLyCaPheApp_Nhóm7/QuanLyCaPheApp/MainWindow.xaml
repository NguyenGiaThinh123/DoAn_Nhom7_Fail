<Window x:Class="QuanLyCaPheApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Quán Cà Phê" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="215"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR TRÁI -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,18,20,15"
                        BorderBrush="#4A2C22" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="☕ CAFE MANAGER" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock x:Name="txtUserInfo" Text="Xin chào!" FontSize="11"
                                   Foreground="#BCAAA4" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Nút đăng xuất -->
                <Border DockPanel.Dock="Bottom" Padding="12,10"
                        BorderBrush="#4A2C22" BorderThickness="0,1,0,0">
                    <Button x:Name="btnLogout" Content="Đăng Xuất"
                            Style="{StaticResource DangerButton}"
                            Click="btnLogout_Click" HorizontalAlignment="Stretch"/>
                </Border>

                <!-- Menu điều hướng -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">
                        <Button x:Name="btnTrangChu"
                                Content="  Trang Chủ"
                                Style="{StaticResource NavButtonActive}"
                                Click="NavBtn_Click" Tag="TrangChu"/>
                        <Button x:Name="btnGoiMon"
                                Content="  Gọi Món"
                                Style="{StaticResource NavButton}"
                                Click="NavBtn_Click" Tag="GoiMon"/>
                        <Button x:Name="btnDatBan"
                                Content="  Đặt Bàn"
                                Style="{StaticResource NavButton}"
                                Click="NavBtn_Click" Tag="DatBan"/>
                        <Button x:Name="btnThanhToan"
                                Content="  Thanh Toán"
                                Style="{StaticResource NavButton}"
                                Click="NavBtn_Click" Tag="ThanhToan"/>

                        <Border Height="1" Background="#4A2C22" Margin="16,8"/>

                        <Button x:Name="btnSanPham"
                                Content="  Quản Lý Sản Phẩm"
                                Style="{StaticResource NavButton}"
                                Click="NavBtn_Click" Tag="SanPham"/>
                        <Button x:Name="btnKhachHang"
                                Content="  Quản Lý Khách Hàng"
                                Style="{StaticResource NavButton}"
                                Click="NavBtn_Click" Tag="KhachHang"/>
                        <Button x:Name="btnNguoiDung"
                                Content="  Quản Lý Người Dùng"
                                Style="{StaticResource NavButton}"
                                Click="NavBtn_Click" Tag="NguoiDung"/>

                        <Border Height="1" Background="#4A2C22" Margin="16,8"/>

                        <Button x:Name="btnThongKe"
                                Content="  Thống Kê Doanh Thu"
                                Style="{StaticResource NavButton}"
                                Click="NavBtn_Click" Tag="ThongKe"/>
                        <Button x:Name="btnBaoCao"
                                Content="  Xuất Báo Cáo"
                                Style="{StaticResource NavButton}"
                                Click="NavBtn_Click" Tag="BaoCao"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- NỘI DUNG CHÍNH -->
        <Frame x:Name="MainFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="{StaticResource BackgroundBrush}"/>
    </Grid>
</Window>
