<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.0" />
    <PackageReference Include="ClosedXML" Version="0.102.2" />
  </ItemGroup>

  <!--
    SDK tự động include mọi .xaml thành <Page>.
    Chỉ cần xóa code-behind .cs của ResourceDictionary ra khỏi compilation.
    KHÔNG cần explicit <Page Include> vì sẽ bị duplicate.
  -->
  <ItemGroup>
    <Compile Remove="Resources\Colors.xaml.cs" />
    <Compile Remove="Resources\Styles.xaml.cs" />
  </ItemGroup>
</Project>
