<Page x:Class="QuanLyCaPheApp.Views.QuanLyNguoiDungView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyCaPheApp.ViewModels"
      xmlns:conv="clr-namespace:QuanLyCaPheApp.Converters"
      Title="Quản Lý Người Dùng" Background="{StaticResource BackgroundBrush}">
    <Page.DataContext><vm:QuanLyNguoiDungViewModel/></Page.DataContext>
    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="330"/>
        </Grid.ColumnDefinitions>

        <!-- TRÁI: Danh sách -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Quản Lý Người Dùng" Style="{StaticResource SectionHeader}"/>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="🔍 Tìm kiếm" Style="{StaticResource PrimaryButton}"
                        Height="36" Command="{Binding SearchCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="➕ Thêm Mới" Style="{StaticResource SuccessButton}"
                        Height="36" Command="{Binding ThemCommand}"/>
            </Grid>

            <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding Selected}"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên ĐN" Binding="{Binding TenDangNhap}" Width="120"/>
                    <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoTen}" Width="*"/>
                    <DataGridTextColumn Header="Vai Trò" Binding="{Binding TenVaiTro}" Width="100"/>
                    <DataGridTextColumn Header="Số ĐT" Binding="{Binding SoDienThoai}" Width="115"/>
                    <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThaiText}" Width="95"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- PHẢI: Form -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding ThongBao}" Foreground="{StaticResource SuccessBrush}"
                               FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <!-- Chế độ xem -->
                    <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                        <TextBlock Text="👤 Thông Tin Người Dùng" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding Selected.HoTen}" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Selected.TenDangNhap}" FontSize="12" Margin="0,4"/>
                        <TextBlock Text="{Binding Selected.TenVaiTro}" FontSize="13"
                                   Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Selected.TrangThaiText}" FontSize="12" Margin="0,4"/>
                        <Separator Margin="0,12"/>
                        <Button Content="✏️ Sửa Thông Tin" Style="{StaticResource AccentButton}"
                                Command="{Binding SuaCommand}" Height="36" Margin="0,0,0,8"
                                IsEnabled="{Binding HasSelected}"/>
                        <Button Content="🔒 Khóa / Mở Khóa TK" Style="{StaticResource DangerButton}"
                                Command="{Binding KhoaCommand}" Height="36" Margin="0,0,0,8"
                                IsEnabled="{Binding HasSelected}"/>
                        <Separator Margin="0,4,0,12"/>
                        <TextBlock Text="Đổi Mật Khẩu Nhanh" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding MatKhauMoi, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,8"/>
                        <Button Content="🔑 Đổi Mật Khẩu" Style="{StaticResource SecondaryButton}"
                                Command="{Binding DoiMatKhauCommand}" Height="36"
                                IsEnabled="{Binding HasSelected}"/>
                    </StackPanel>

                    <!-- Form chỉnh sửa -->
                    <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Nhập Thông Tin" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

                        <TextBlock Text="Tên đăng nhập *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.TenDangNhap, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Mật khẩu" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding MatKhauMoi, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Họ tên *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.HoTen, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Điện thoại" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.SoDienThoai, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Vai trò *" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding DanhSachVaiTro}" DisplayMemberPath="TenVaiTro"
                                  SelectedValue="{Binding EditItem.MaVaiTro}" SelectedValuePath="MaVaiTro"
                                  Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"/>

                        <CheckBox Content="Tài khoản đang hoạt động" IsChecked="{Binding EditItem.TrangThai}"
                                  Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="💾 Lưu" Style="{StaticResource SuccessButton}"
                                    Height="38" Command="{Binding LuuCommand}"/>
                            <Button Grid.Column="2" Content="Hủy" Style="{StaticResource SecondaryButton}"
                                    Height="38" Command="{Binding HuyCommand}"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
