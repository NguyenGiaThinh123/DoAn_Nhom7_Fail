<Page x:Class="QuanLyCaPheApp.Views.QuanLyKhachHangView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyCaPheApp.ViewModels"
      xmlns:conv="clr-namespace:QuanLyCaPheApp.Converters"
      Title="Quản Lý Khách Hàng" Background="{StaticResource BackgroundBrush}">
    <Page.DataContext><vm:QuanLyKhachHangViewModel/></Page.DataContext>
    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="330"/>
        </Grid.ColumnDefinitions>

        <!-- TRÁI -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="155"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Quản Lý Khách Hàng" Style="{StaticResource SectionHeader}"/>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="🔍 Tìm kiếm" Style="{StaticResource PrimaryButton}"
                        Height="36" Command="{Binding SearchCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="➕ Thêm Khách" Style="{StaticResource SuccessButton}"
                        Height="36" Command="{Binding ThemCommand}"/>
            </Grid>

            <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSach}"
                      SelectedItem="{Binding Selected}"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoTen}" Width="*"/>
                    <DataGridTextColumn Header="Số ĐT" Binding="{Binding SoDienThoai}" Width="115"/>
                    <DataGridTextColumn Header="Hạng" Binding="{Binding HangKhachHang}" Width="95"/>
                    <DataGridTextColumn Header="Điểm" Binding="{Binding DiemText}" Width="90"/>
                    <DataGridTextColumn Header="Chi Tiêu" Binding="{Binding ChiTieuText}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Lịch sử điểm tích lũy -->
            <TextBlock Grid.Row="3" Text="⭐ Lịch Sử Tích Điểm" FontWeight="SemiBold" FontSize="13"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,12,0,8"/>
            <DataGrid Grid.Row="4" ItemsSource="{Binding LichSuDiem}"
                      Style="{StaticResource ModernDataGrid}" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Loại GD" Binding="{Binding LoaiText}" Width="100"/>
                    <DataGridTextColumn Header="Điểm" Binding="{Binding SoDiemText}" Width="70"/>
                    <DataGridTextColumn Header="Còn lại" Binding="{Binding SoDiemSauGD}" Width="70"/>
                    <DataGridTextColumn Header="Mô tả" Binding="{Binding MoTa}" Width="*"/>
                    <DataGridTextColumn Header="Ngày" Binding="{Binding NgayGiaoDich, StringFormat='dd/MM/yyyy'}" Width="95"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- PHẢI: Form -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding ThongBao}" Foreground="{StaticResource SuccessBrush}"
                               FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <!-- Chế độ xem -->
                    <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                        <TextBlock Text="👤 Thông Tin Khách Hàng" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding Selected.HoTen}" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Selected.SoDienThoai}" FontSize="13" Margin="0,4,0,4"/>
                        <TextBlock Text="{Binding Selected.HangKhachHang}" Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="{Binding Selected.DiemText}" FontSize="13" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding Selected.ChiTieuText}" FontSize="13"/>
                        <Separator Margin="0,12"/>
                        <Button Content="✏️ Sửa Thông Tin" Style="{StaticResource AccentButton}"
                                Command="{Binding SuaCommand}" Height="36" Margin="0,0,0,8"
                                IsEnabled="{Binding HasSelected}"/>
                        <Button Content="🗑️ Xóa Khách Hàng" Style="{StaticResource DangerButton}"
                                Command="{Binding XoaCommand}" Height="36"
                                IsEnabled="{Binding HasSelected}"/>
                    </StackPanel>

                    <!-- Form chỉnh sửa -->
                    <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Nhập Thông Tin Khách" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

                        <TextBlock Text="Họ tên *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.HoTen, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Số điện thoại *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.SoDienThoai, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Địa chỉ" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.DiaChi, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Ghi chú" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.GhiChu, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="60"
                                 TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="💾 Lưu" Style="{StaticResource SuccessButton}"
                                    Height="38" Command="{Binding LuuCommand}"/>
                            <Button Grid.Column="2" Content="Hủy" Style="{StaticResource SecondaryButton}"
                                    Height="38" Command="{Binding HuyCommand}"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
