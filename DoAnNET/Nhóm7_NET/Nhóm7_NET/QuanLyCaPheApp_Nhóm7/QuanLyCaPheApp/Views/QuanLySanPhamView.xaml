<Page x:Class="QuanLyCaPheApp.Views.QuanLySanPhamView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyCaPheApp.ViewModels"
      xmlns:conv="clr-namespace:QuanLyCaPheApp.Converters"
      Title="Quản Lý Sản Phẩm" Background="{StaticResource BackgroundBrush}">
    <Page.DataContext><vm:QuanLySanPhamViewModel/></Page.DataContext>
    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- TRÁI: Danh sách sản phẩm -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Quản Lý Sản Phẩm" Style="{StaticResource SectionHeader}"/>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="165"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Height="36"
                         Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding DanhSachLoai}"
                          SelectedValue="{Binding FilterLoai}" SelectedValuePath="MaLoai"
                          DisplayMemberPath="TenLoai"
                          Style="{StaticResource ModernComboBox}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="🔍 Tìm kiếm" Style="{StaticResource PrimaryButton}"
                        Height="36" Margin="0,0,8,0" Command="{Binding SearchCommand}"/>
                <Button Grid.Column="3" Content="➕ Thêm Mới" Style="{StaticResource SuccessButton}"
                        Height="36" Command="{Binding ThemCommand}"/>
            </Grid>

            <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSach}"
                      SelectedItem="{Binding Selected}"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding MaSanPham}" Width="45"/>
                    <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding TenSanPham}" Width="*"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding TenLoai}" Width="110"/>
                    <DataGridTextColumn Header="Giá Bán" Binding="{Binding GiaBanText}" Width="110"/>
                    <DataGridTextColumn Header="Giảm" Binding="{Binding PhanTramGiamText}" Width="60"/>
                    <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonVi}" Width="65"/>
                    <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThaiText}" Width="95"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- PHẢI: Form nhập liệu -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding ThongBao}" Foreground="{StaticResource SuccessBrush}"
                               FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <!-- Chế độ xem -->
                    <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                        <TextBlock Text="Chi Tiết Sản Phẩm" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding Selected.TenSanPham}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Selected.GiaBanText}" FontSize="18"
                                   Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Selected.MoTa}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,8,0,16"/>
                        <Button Content="✏️ Sửa Sản Phẩm" Style="{StaticResource AccentButton}"
                                Command="{Binding SuaCommand}" Height="36" Margin="0,0,0,8"
                                IsEnabled="{Binding HasSelected}"/>
                        <Button Content="🗑️ Ẩn / Xóa Sản Phẩm" Style="{StaticResource DangerButton}"
                                Command="{Binding XoaCommand}" Height="36"
                                IsEnabled="{Binding HasSelected}"/>
                        <Separator Margin="0,16"/>
                        <Button Content="➕ Thêm Loại Sản Phẩm" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ThemLoaiCommand}" Height="36"/>
                    </StackPanel>

                    <!-- Form chỉnh sửa -->
                    <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Nhập Thông Tin Sản Phẩm" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

                        <TextBlock Text="Tên sản phẩm *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.TenSanPham, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Loại sản phẩm *" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding DanhSachLoai}" DisplayMemberPath="TenLoai"
                                  SelectedValue="{Binding EditItem.MaLoai}" SelectedValuePath="MaLoai"
                                  Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Giá bán (đ) *" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding EditItem.GiaBan, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="36"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="% Giảm giá" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding EditItem.PhanTramGiam, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="36"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Đơn vị tính" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.DonVi, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="36" Margin="0,0,0,10"/>

                        <TextBlock Text="Mô tả" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditItem.MoTa, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="70"
                                 TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>

                        <CheckBox Content="Đang kinh doanh" IsChecked="{Binding EditItem.TrangThai}"
                                  Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="💾 Lưu" Style="{StaticResource SuccessButton}"
                                    Height="38" Command="{Binding LuuCommand}"/>
                            <Button Grid.Column="2" Content="Hủy" Style="{StaticResource SecondaryButton}"
                                    Height="38" Command="{Binding HuyCommand}"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
