<Page x:Class="QuanLyCaPheApp.Views.ThongKeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyCaPheApp.ViewModels"
      xmlns:conv="clr-namespace:QuanLyCaPheApp.Converters"
      Title="Thong Ke Doanh Thu" Background="{StaticResource BackgroundBrush}">
    <Page.DataContext><vm:ThongKeDoanhThuViewModel/></Page.DataContext>
    <Page.Resources>
        <conv:NumberFormatConverter x:Key="NumFmt"/>
    </Page.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Thong Ke Doanh Thu" Style="{StaticResource SectionHeader}"/>

        <!-- Filter -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Tu ngay:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding TuNgay}" Height="34" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" Text="Den ngay:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding DenNgay}" Height="34" Margin="0,0,12,0"/>
                <Button Grid.Column="4" Content="Tra cuu" Style="{StaticResource PrimaryButton}"
                        Height="34" Command="{Binding TraCuuCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="5" Content="Hom nay" Style="{StaticResource SecondaryButton}"
                        Height="34" Command="{Binding HomNayCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="6" Content="Thang nay" Style="{StaticResource SecondaryButton}"
                        Height="34" Command="{Binding ThangNayCommand}"/>
            </Grid>
        </Border>

        <!-- KPI Summary -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Tong Doanh Thu" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TongDTText}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Tong Hoa Don" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TongHoaDon}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource InfoBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Tong Giam Gia" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TongGiamGia, Converter={StaticResource NumFmt}}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Doanh thu theo ngay -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding DanhSach}"
                  Style="{StaticResource ModernDataGrid}" Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ngay" Binding="{Binding NgayText}" Width="110"/>
                <DataGridTextColumn Header="So Hoa Don" Binding="{Binding SoHoaDon}" Width="100"/>
                <DataGridTextColumn Header="Doanh Thu Goc" Binding="{Binding DoanhThuGoc, Converter={StaticResource NumFmt}}" Width="*"/>
                <DataGridTextColumn Header="Tong Giam" Binding="{Binding TongGiamGia, Converter={StaticResource NumFmt}}" Width="*"/>
                <DataGridTextColumn Header="Thuc Thu" Binding="{Binding ThucThuText}" Width="*"/>
                <DataGridTextColumn Header="So Khach" Binding="{Binding SoKhachHang}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Top san pham -->
        <TextBlock Grid.Row="4" Text="Top 10 San Pham Ban Chay Nhat" FontWeight="Bold" FontSize="14"
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
        <DataGrid Grid.Row="5" ItemsSource="{Binding TopSanPham}"
                  Style="{StaticResource ModernDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ten San Pham" Binding="{Binding TenSanPham}" Width="*"/>
                <DataGridTextColumn Header="So Luong" Binding="{Binding TongSoLuong}" Width="100"/>
                <DataGridTextColumn Header="Doanh Thu" Binding="{Binding TongDoanhThuText}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
