<Page x:Class="QuanLyCaPheApp.Views.ThanhToanView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyCaPheApp.ViewModels"
      xmlns:conv="clr-namespace:QuanLyCaPheApp.Converters"
      Title="Thanh Toán" Background="{StaticResource BackgroundBrush}">
    <Page.DataContext><vm:ThanhToanViewModel/></Page.DataContext>
    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NumberFormatConverter x:Key="NumFmt"/>
    </Page.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="370"/>
        </Grid.ColumnDefinitions>

        <!-- TRÁI: Danh sách hóa đơn -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="185"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="🧾 Hóa Đơn Đang Gọi" Style="{StaticResource SectionHeader}"/>
                <Button Content="🔄 Làm Mới" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Right" Command="{Binding LoadCommand}"/>
            </Grid>

            <!-- Tìm khách hàng nhanh -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSDT" Style="{StaticResource ModernTextBox}" Height="34"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="🔍 Tìm Khách" Style="{StaticResource AccentButton}"
                            Height="34" Margin="0,0,8,0"
                            Command="{Binding TimKhachCommand}"
                            CommandParameter="{Binding Text, ElementName=txtSDT}"/>
                    <TextBlock Grid.Column="2" Text="{Binding TenKhach}" VerticalAlignment="Center"
                               FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="8,0"/>
                </Grid>
            </Border>

            <!-- Danh sách hóa đơn -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSachHD}"
                      SelectedItem="{Binding Selected}"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding MaHoaDon}" Width="45"/>
                    <DataGridTextColumn Header="Bàn" Binding="{Binding TenBan}" Width="75"/>
                    <DataGridTextColumn Header="Khách Hàng" Binding="{Binding TenKhachHang}" Width="*"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding LoaiHoaDonText}" Width="80"/>
                    <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TongThanhToanText}" Width="110"/>
                    <DataGridTextColumn Header="Giờ tạo" Binding="{Binding NgayTao, StringFormat='HH:mm dd/MM'}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Chi tiết món gọi -->
            <TextBlock Grid.Row="3" Text="📋 Chi Tiết Các Món Đã Gọi:" FontWeight="SemiBold" Margin="0,12,0,8"/>
            <DataGrid Grid.Row="4" ItemsSource="{Binding Selected.ChiTiet}"
                      Style="{StaticResource ModernDataGrid}" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên Món" Binding="{Binding TenSanPham}" Width="*"/>
                    <DataGridTextColumn Header="Đơn Giá" Binding="{Binding DonGiaText}" Width="95"/>
                    <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="40"/>
                    <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTienText}" Width="110"/>
                    <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThaiText}" Width="105"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- PHẢI: Panel thanh toán -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="💳 Thanh Toán" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

                    <!-- Bảng tính tiền -->
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="12">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Tổng tạm tính:"/>
                                <TextBlock Text="{Binding TongTamTinh, Converter={StaticResource NumFmt}}"
                                           HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Giảm giá (KM + điểm):" Foreground="{StaticResource SuccessBrush}"/>
                                <TextBlock Text="{Binding SoTienGiam, Converter={StaticResource NumFmt}}"
                                           HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}"/>
                            </Grid>
                            <Separator/>
                            <Grid Margin="0,6,0,0">
                                <TextBlock Text="💰 Thực Thu:" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding TongThanhToan, Converter={StaticResource NumFmt}}"
                                           HorizontalAlignment="Right" FontWeight="Bold" FontSize="17"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Mã khuyến mãi -->
                    <TextBlock Text="Mã khuyến mãi" Style="{StaticResource FormLabel}" Margin="0,14,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding MaCode, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="34" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Áp dụng" Style="{StaticResource AccentButton}"
                                Height="34" Command="{Binding ApDungMaCommand}"/>
                    </Grid>
                    <ComboBox ItemsSource="{Binding DanhSachKM}" DisplayMemberPath="ThongTinKM"
                              SelectedItem="{Binding SelectedKM}"
                              Style="{StaticResource ModernComboBox}" Margin="0,6,0,0"/>

                    <!-- Dùng điểm tích lũy -->
                    <TextBlock Text="{Binding DiemToiDa, StringFormat='⭐ Dùng điểm tích lũy (tối đa {0} điểm):'}"
                               Style="{StaticResource FormLabel}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding DiemDung, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" Height="34"/>
                    <TextBlock Text="100 điểm = giảm 10.000đ" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3"/>

                    <!-- Tiền khách đưa -->
                    <TextBlock Text="Tiền khách đưa (đ)" Style="{StaticResource FormLabel}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding TienKhachDua, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" Height="34"/>
                    <TextBlock Text="{Binding TienThua, Converter={StaticResource NumFmt}, StringFormat='💵 Tiền thừa: {0}'}"
                               FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource SuccessBrush}" Margin="0,6"/>

                    <!-- Phương thức thanh toán -->
                    <TextBlock Text="Phương thức thanh toán" Style="{StaticResource FormLabel}" Margin="0,8,0,4"/>
                    <ComboBox ItemsSource="{Binding PhuongThucList}" SelectedItem="{Binding PhuongThuc}"
                              Style="{StaticResource ModernComboBox}" Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding ThongBao}" Foreground="{StaticResource SuccessBrush}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Button Content="✅ THANH TOÁN" Style="{StaticResource SuccessButton}"
                            Height="46" FontSize="15" Command="{Binding ThanhToanCommand}"
                            IsEnabled="{Binding HasHoaDon}" Margin="0,0,0,8"/>
                    <Button Content="❌ Hủy Hóa Đơn" Style="{StaticResource DangerButton}"
                            Height="36" Command="{Binding HuyHoaDonCommand}"
                            IsEnabled="{Binding HasHoaDon}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
