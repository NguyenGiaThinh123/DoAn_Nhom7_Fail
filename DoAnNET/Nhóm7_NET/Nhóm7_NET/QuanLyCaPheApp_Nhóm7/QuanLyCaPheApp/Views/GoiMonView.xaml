<Page x:Class="QuanLyCaPheApp.Views.GoiMonView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyCaPheApp.ViewModels"
      xmlns:conv="clr-namespace:QuanLyCaPheApp.Converters"
      Title="Gọi Món" Background="{StaticResource BackgroundBrush}">
    <Page.DataContext><vm:GoiMonViewModel/></Page.DataContext>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="330"/>
        </Grid.ColumnDefinitions>

        <!-- TRÁI: Menu sản phẩm -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Chọn bàn -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Chọn bàn: " VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding DanhSachBan}" DisplayMemberPath="TenBan"
                          SelectedItem="{Binding SelectedBan}" Style="{StaticResource ModernComboBox}" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding TenBanHienTai}" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Grid.Column="3" Content="🔄 Làm Mới" Style="{StaticResource SecondaryButton}"
                        Height="34" Command="{Binding RefreshMenuCommand}"/>
            </Grid>

            <!-- Tìm kiếm + lọc loại -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Height="34"
                         Margin="0,0,8,0" Tag="🔍 Tìm tên món..."/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding DanhSachLoai}" DisplayMemberPath="TenLoai"
                          SelectedValue="{Binding FilterLoai}" SelectedValuePath="MaLoai"
                          Style="{StaticResource ModernComboBox}"/>
            </Grid>

            <!-- Danh sách món -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding MenuItems}" SelectedItem="{Binding SelectedSP}"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên Món" Binding="{Binding TenSanPham}" Width="*"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding TenLoai}" Width="100"/>
                    <DataGridTextColumn Header="Giá Bán" Binding="{Binding GiaBanText}" Width="110"/>
                    <DataGridTextColumn Header="Giảm" Binding="{Binding PhanTramGiamText}" Width="65"/>
                    <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonVi}" Width="65"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- PHẢI: Giỏ hàng / Đơn gọi -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Nút thêm món -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="🛒 Đơn Gọi Món" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ThongBao}" FontSize="11"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,4"/>
                    <Button Content="➕ Thêm Món Vào Đơn" Style="{StaticResource PrimaryButton}"
                            Height="38" Command="{Binding ThemVaoGioCommand}"
                            ToolTip="Chọn món trong danh sách rồi bấm thêm"/>
                </StackPanel>
            </Border>

            <!-- Các món đã gọi -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Các Món Đã Gọi" FontWeight="SemiBold" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding GioHang}"
                              Style="{StaticResource ModernDataGrid}" FontSize="12" MaxHeight="360">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên Món" Binding="{Binding TenSanPham}" Width="*"/>
                            <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="35"/>
                            <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTienText}" Width="95"/>
                            <DataGridTemplateColumn Header="Xóa" Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Foreground="Red" FontWeight="Bold"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.XoaKhoiGioCommand,
                                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Tổng tiền -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tổng Tạm Tính:" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Grid.Column="1" Text="{Binding TongTienText}"
                                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    </Grid>
                    <TextBlock Text="★ 1.000đ = 1 điểm tích lũy" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
